    {
      "name": "InChIKey",
      "definition_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/InChIKey",
      "annotations": [
        {
          "tag": "database",
          "value": "IUPAC",
          "@type": "Annotation"
        },
        {
          "tag": "prefix",
          "value": "inchikey",
          "@type": "Annotation"
        },
        {
          "tag": "base_uri",
