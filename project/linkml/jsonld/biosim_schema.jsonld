      "domain_of": [
        "MoleculeID"
      ],
      "range": "string",
      "pattern": "^[A-Z]{14}-[A-Z]{10}(-[A-Z])?$",
      "@type": "SlotDefinition"
    },
    {
      "name": "SMILES",
      "definition_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/SMILES",
      "annotations": [
        {
          "tag": "engine_mapping",
          "value": [
            {
              "engine": "toptrajparser",
              "key": "SMILES"
            }
          ],
          "@type": "Annotation"
        },
        {
          "tag": "example",
          "value": [
            {
              "value": "CN1C=NC2=C1C(=O)N(C(=O)N2C)C"
            }
          ],
          "@type": "Annotation"
        }
      ],
      "description": "Simplified Molecular Input Line Entry System (SMILES) ASCII-based line notation used to describe chemical structures. It represents molecular graphs with atoms and bonds, allowing software to convert these short strings into 2D or 3D models.",
      "examples": [
        {
          "value": "CN1C=NC2=C1C(=O)N(C(=O)N2C)C",
          "@type": "Example"
        }
      ],
      "from_schema": "https://CCPBioSim.ac.uk/biosim-schema/composition",
      "aliases": [
        "SMILES"
      ],
      "slot_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/SMILES",
      "owner": "MoleculeID",
      "domain_of": [
        "MoleculeID"
      ],
      "range": "string",
      "pattern": "^[A-Za-z0-9@+\\-\\[\\]()=#$:./\\\\%*]+$",
      "@type": "SlotDefinition"
    },
    {
      "name": "InChI",
      "definition_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/InChI",
      "annotations": [
        {
          "tag": "engine_mapping",
          "value": [
            {
              "engine": "toptrajparser",
              "key": "InChI"
            }
          ],
          "@type": "Annotation"
        },
        {
          "tag": "example",
          "value": [
            {
              "value": "InChI=1S/C8H10N4O2/c1-10-4-9-6-5(10)7(13)12(3)8(14)11(6)2/h4H,1-3H3"
            }
          ],
          "@type": "Annotation"
        }
      ],
      "description": "The International Chemical Identifier (InChi) is a textual identifier for chemical substances, designed to provide a standard way to encode molecular information",
      "examples": [
        {
          "value": "InChI=1S/C8H10N4O2/c1-10-4-9-6-5(10)7(13)12(3)8(14)11(6)2/h4H,1-3H3",
          "@type": "Example"
        }
      ],
      "from_schema": "https://CCPBioSim.ac.uk/biosim-schema/composition",
      "aliases": [
        "InChI"
      ],
      "slot_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/InChI",
      "owner": "MoleculeID",
      "domain_of": [
        "MoleculeID"
      ],
      "range": "string",
      "pattern": "^InChI=1S?/[A-Za-z0-9.+\\-]+(/[a-z][^/]*)*$",
      "@type": "SlotDefinition"
    },
    {
      "name": "molecular_formula",
      "definition_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/molecular_formula",
      "annotations": [
        {
          "tag": "engine_mapping",
          "value": [
            {
              "engine": "toptrajparser",
              "key": "molecular_formula"
            }
          ],
          "@type": "Annotation"
