          ]
        },
        {
          "text": "\u03bcVT",
          "description": "Grand canonical ensemble (\u03bcVT) with constant chemical potential, volume and temperature.",
          "annotations": [
            {
              "tag": "engine_mapping",
              "value": [
                {
                  "engine": "amber",
