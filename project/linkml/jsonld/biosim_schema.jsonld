        },
        {
          "tag": "engine_mapping",
          "value": [
            {
              "engine": "toptrajparser",
              "key": "InChIKey"
            }
          ],
          "@type": "Annotation"
        },
        {
          "tag": "example",
          "value": [
            {
              "value": "RYYVLZVUVIJVGH-UHFFFAOYSA-N"
            }
          ],
          "@type": "Annotation"
        }
      ],
      "description": "The condensed, 27 character InChIKey, which is a hashed version of the full InChI (using the SHA-256 algorithm), designed to allow for easy web searches of chemical compounds.",
      "examples": [
        {
          "value": "RYYVLZVUVIJVGH-UHFFFAOYSA-N",
          "@type": "Example"
        }
      ],
      "from_schema": "https://CCPBioSim.ac.uk/biosim-schema/composition",
      "aliases": [
