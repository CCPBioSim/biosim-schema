        {
          "tag": "example",
          "value": [
            {
              "value": "C8H10N4O2"
            }
          ],
          "@type": "Annotation"
        }
      ],
      "description": "The molecular formula of a molecule\\",
      "examples": [
        {
          "value": "C8H10N4O2",
          "@type": "Example"
        }
      ],
      "from_schema": "https://CCPBioSim.ac.uk/biosim-schema/composition",
      "slot_uri": "https://CCPBioSim.ac.uk/biosim-schema/composition/molecular_formula",
      "owner": "MoleculeID",
      "domain_of": [
        "MoleculeID"
      ],
      "range": "string",
      "pattern": "^([A-Z][a-z]?\\d*)+$",
      "@type": "SlotDefinition"
