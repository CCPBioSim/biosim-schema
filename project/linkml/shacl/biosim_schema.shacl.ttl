@prefix biosim_schema: <https://CCPBioSim.ac.uk/biosim-schema/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

biosim_schema:SimulationMetadata a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/topology/TopologyMetadata> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path biosim_schema:topology ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/settings/SimulationSettings> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path biosim_schema:settings ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/stages/SimulationStages> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path biosim_schema:stages ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/composition/SystemComposition> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path biosim_schema:composition ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/observables/SimulationObservables> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path biosim_schema:observables ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/trajectory/TrajectoryMetadata> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path biosim_schema:trajectory ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/potentials/PotentialMetadata> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path biosim_schema:potentials ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/compute/ComputationalEnvironment> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path biosim_schema:compute ] ;
    sh:targetClass biosim_schema:SimulationMetadata .

<https://CCPBioSim.ac.uk/biosim-schema/quantities/AngleQuantity> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/value> ],
        [ sh:defaultValue "degrees" ;
            sh:in ( "degrees" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/value_unit> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/quantities/AngleQuantity> .

<https://CCPBioSim.ac.uk/biosim-schema/quantities/MatrixQuantity> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/vector_value> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/value_unit> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/quantities/MatrixQuantity> .

<https://CCPBioSim.ac.uk/biosim-schema/quantities/VectorCompressibilityQuantity> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:defaultValue "1/bar" ;
            sh:in ( qudt:PER-BAR qudt:PER-PA ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/value_unit> ],
        [ sh:datatype xsd:float ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/vector_value> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/quantities/VectorCompressibilityQuantity> .

<https://CCPBioSim.ac.uk/biosim-schema/quantities/VectorPressureQuantity> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:defaultValue "bar" ;
            sh:in ( "bar" "Pa" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/value_unit> ],
        [ sh:datatype xsd:float ;
            sh:maxCount 3 ;
            sh:minCount 3 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/quantities/vector_value> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/quantities/VectorPressureQuantity> .

<https://CCPBioSim.ac.uk/biosim-schema/composition/MoleculeID> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/ChargeQuantity> ;
            sh:description "Electrostatic charge of a molecule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/molecule_charge> ;
            sh:pattern "^[+-]?\\d+(\\.\\d+)?$" ],
        [ sh:datatype xsd:string ;
            sh:description "The International Chemical Identifier (InChi) is a textual identifier for chemical substances, designed to provide a standard way to encode molecular information" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/InChI> ;
            sh:pattern "^InChI=1S?/[A-Za-z0-9.+\\-]+(/[a-z][^/]*)*$" ],
        [ sh:datatype xsd:string ;
            sh:description "PubChem CID of chemical molecules and their activities against biological assays." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/PubChem_CID> ;
            sh:pattern "^\\d+$" ],
        [ sh:datatype xsd:string ;
            sh:description "The condensed, 27 character InChIKey, which is a hashed version of the full InChI (using the SHA-256 algorithm), designed to allow for easy web searches of chemical compounds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/InChIKey> ;
            sh:pattern "^[A-Z]{14}-[A-Z]{10}(-[A-Z])?$" ],
        [ sh:datatype xsd:string ;
            sh:description "One letter sequence for protein amino acids." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/protein_sequence> ;
            sh:pattern "^[ACDEFGHIKLMNPQRSTVWY]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "AlphaFold predicted protein structure identifier (AlphaFold DB, EMBL-EBI)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/alphafold_ID> ;
            sh:pattern "^AF-[A-Z0-9]+-F1$" ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/UNIPROT_ID> ;
            sh:pattern "^[A-Z0-9]{6,10}$" ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/MassQuantity> ;
            sh:description "The molecular weight of a molecule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/molecular_weight> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Has the initial model been modified from the original?" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/modified> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Are the molecule positions derived from a prediction?" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/predicted_structure> ],
        [ sh:datatype xsd:string ;
            sh:description "The molecular formula of a molecule\\" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/molecular_formula> ;
            sh:pattern "^([A-Z][a-z]?\\d*)+$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of monomeric units in a polymer(e.g. protein or nucleic acid)." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/monomer_count> ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of atoms in a molecule." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/atom_count> ],
        [ sh:datatype xsd:string ;
            sh:description "Protein Data Bank identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/PDB_ID> ;
            sh:pattern "^[0-9A-Za-z]{4}$" ],
        [ sh:datatype xsd:string ;
            sh:description "One letter sequence for nucleic acid nucleotides." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/nucleic_sequence> ;
            sh:pattern "^[ACGTURYSWKMBDHVN]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Simplified Molecular Input Line Entry System (SMILES) ASCII-based line notation used to describe chemical structures. It represents molecular graphs with atoms and bonds, allowing software to convert these short strings into 2D or 3D models." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/SMILES> ;
            sh:pattern "^[A-Za-z0-9@+\\-\\[\\]()=#$:./\\\\%*]+$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of instances of a given molecule, defined as bonded atoms or beads." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/molecule_count> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/composition/MoleculeID> .

<https://CCPBioSim.ac.uk/biosim-schema/composition/SystemComposition> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/composition/SystemCounts> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/system_counts> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/composition/MoleculeID> ;
            sh:description "Persistent identifier of a molecule being simulated." ;
            sh:maxCount 20 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/molecule_ID> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/composition/SystemComposition> .

<https://CCPBioSim.ac.uk/biosim-schema/composition/SystemCounts> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Total number of atoms in the simulation." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/total_atom_count> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/ConcentrationQuantity> ;
            sh:description "Concentration of salt in the solution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/salt_concentration> ],
        [ sh:datatype xsd:integer ;
            sh:description "Total number of simulated molecules, defined as bonded atoms or beads." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/total_molecule_count> ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of unique simulated molecules, defined as bonded atoms or beads." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/composition/unique_molecule_count> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/composition/SystemCounts> .

<https://CCPBioSim.ac.uk/biosim-schema/compute/ComputationalEnvironment> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/compute/Hardware> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/hardware> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/compute/Performance> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/performance> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/compute/Software> ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/software> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/compute/ComputationalEnvironment> .

<https://CCPBioSim.ac.uk/biosim-schema/compute/Hardware> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Number of hardware threads per physical core." ;
            sh:maxCount 1 ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/threads_per_core> ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of physical CPU sockets in each compute node." ;
            sh:maxCount 1 ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/sockets_per_node> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/ByteQuantity> ;
            sh:description "Amount of memory installed per compute node." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/memory_per_node> ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of compute nodes used for the run." ;
            sh:maxCount 1 ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/node_count> ],
        [ sh:description "Broad type of system used to run the simulation workload." ;
            sh:in ( "HPC Cluster" "Cloud VM" "Local" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/execution_platform> ],
        [ sh:description "CPU instruction-set architecture of the compute nodes." ;
            sh:in ( "x86" "ARM" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/CPU_architecture> ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of GPUs present in each compute node." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/GPUs_per_node> ],
        [ sh:description "GPU vendor used by the compute nodes, if applicable." ;
            sh:in ( "Nvidia" "AMD" "Intel" "None" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/GPU_vendor> ],
        [ sh:description "Compute node profile used for the simulation run." ;
            sh:in ( "CPU only" "GPU Accelerated" "Hybrid CPU GPU" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/node_type> ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of physical CPU cores in each socket." ;
            sh:maxCount 1 ;
            sh:minInclusive 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/cores_per_socket> ],
        [ sh:description "CPU vendor used in the compute nodes." ;
            sh:in ( "AMD" "Intel" "ARM" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/CPU_vendor> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/compute/Hardware> .

<https://CCPBioSim.ac.uk/biosim-schema/compute/Performance> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/TimeQuantity> ;
            sh:description "Total elapsed runtime of the simulation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/wall_time> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/EnergyQuantity> ;
            sh:description "Total energy consumed by the simulation run." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/energy_consumption> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/compute/Performance> .

<https://CCPBioSim.ac.uk/biosim-schema/compute/Software> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "MPI implementation used for distributed parallel execution." ;
            sh:in ( "OpenMPI" "MPICH" "IntelMPI" "MVAPICH2" "None" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/MPI_library> ],
        [ sh:description "Container runtime used to execute the simulation environment, if any." ;
            sh:in ( "Apptainer" "Docker" "Podman" "None" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/container_runtime> ],
        [ sh:description "Workload manager or job scheduler used to launch the simulation." ;
            sh:in ( "SLURM" "PBS" "LSF" "SGE" "None" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/scheduler> ],
        [ sh:description "Operating system installed on the hardware used to perform the simulation." ;
            sh:in ( "Linux" "macOS" "Windows" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/compute/operating_system> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/compute/Software> .

<https://CCPBioSim.ac.uk/biosim-schema/observables/SimulationAverages> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/MolarEnergyQuantity> ;
            sh:description "Average enthalpy sampled from the simulation, given as a float." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_enthalpy> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/MolarEnergyQuantity> ;
            sh:description "Average potential energy sampled from the simulation, given as a float." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_potential_energy> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/VectorVolumeQuantity> ;
            sh:description "Average volume sampled from the simulation, given as a list, (e.g. 10, 10, 10)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_volume_vector> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/MolarEnergyQuantity> ;
            sh:description "Average kinetic energy sampled from the simulation, given as a float." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_kinetic_energy> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/PressureQuantity> ;
            sh:description "Average pressure sampled from the simulation, given as a float." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_pressure> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/VolumeQuantity> ;
            sh:description "Average volume sampled from the simulation, given as a float." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_volume> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/TemperatureQuantity> ;
            sh:description "Average temperature sampled from the simulation, given as a float." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/average_temperature> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/observables/SimulationAverages> .

<https://CCPBioSim.ac.uk/biosim-schema/observables/SimulationObservables> a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/observables/SimulationAverages> ;
            sh:description "Average values of observables outputted from the simulation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/observables/simulation_averages> ] ;
    sh:targetClass <https://CCPBioSim.ac.uk/biosim-schema/observables/SimulationObservables> .

