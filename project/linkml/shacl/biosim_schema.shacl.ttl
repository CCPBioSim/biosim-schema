            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://CCPBioSim.ac.uk/biosim-schema/settings/pressure_coupling_frequency> ],
        [ sh:class <https://CCPBioSim.ac.uk/biosim-schema/quantities/MatrixPressureQuantity> ;
